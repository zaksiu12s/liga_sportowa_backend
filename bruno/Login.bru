meta {
  name: Login
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/auth/v1/token?grant_type=password
  body: json
  auth: none
}

params:query {
  grant_type: "password"
}

body:json {
  {
    "email": "admin@admin.com",
    "password": ""
  }
}

vars:post-response {
  accessToken: res.body.access_token
}
